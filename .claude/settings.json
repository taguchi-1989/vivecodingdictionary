{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/validate_entry.py"
          },
          {
            "type": "command",
            "command": "python3 scripts/update_review_queue.py --quiet"
          }
        ]
      }
    ]
  }
}
